rules_version = '2';
// Deploy in Firebase Console → Storage → Rules (this file is not auto-deployed).
// Uploads from studio.html require request.auth != null (Firebase Auth session).
service firebase.storage {
  match /b/{bucket}/o {
    match /{album}/{title}/{artist}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /boostUploads/{uploaderId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
