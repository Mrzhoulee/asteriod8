+            if let key = scene.windows.first(where: { $0.isKeyWindow }) {
+                return key
+            }
+        }
+        for scene in scenes {
+            if let first = scene.windows.first {
+                return first
+            }
+        }
+        let flat = scenes.flatMap(\.windows)
+        if let w = flat.first {
+            return w
+        }
+        return UIWindow(frame: UIScreen.main.bounds)
+    }
