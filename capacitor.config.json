{
  "appId": "com.asteroid.asteroidinc8",
  "appName": "Asteroid",
  "webDir": "www",
  "ios": {
    "webContentsDebuggingEnabled": true
  },
  "plugins": {
    "LottieSplashscreen": {
      "launchAutoShow": true,
      "launchAnimationName": "public/splash",
      "launchLoop": true,
      "launchSpeed": 1,
      "launchBackgroundColor": "#020617",
      "launchAutoHideMs": 2500,
      "launchSafetyHideMs": 7000
    }
  },
  "server": {
    "iosScheme": "ionic",
    "allowNavigation": [
      "https://appleid.apple.com",
      "https://www.apple.com",
      "https://apple.com",
      "https://idmsa.apple.com",
      "https://*.apple.com",
      "https://asteroid-cdc13.firebaseapp.com",
      "https://*.firebaseapp.com",
      "https://accounts.google.com",
      "https://*.google.com",
      "https://*.googleapis.com",
      "https://securetoken.googleapis.com",
      "https://buy.stripe.com",
      "https://*.stripe.com"
    ]
  }
}
