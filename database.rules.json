{
  "rules": {
    "owner_token": { ".read": false, ".write": true },
    "boostSongs": { ".read": true, ".write": true, "$boostId": { ".validate": "newData.hasChildren()" } },
    "SONGS": { ".read": true, ".write": "auth != null" },
    "songplayed": { ".read": true, ".write": true },
    "songPlayed": { ".read": true, ".write": true },
    "PROFILEVIEWS": {
      "$profileKey": {
        ".read": true,
        ".write": true
      }
    },
    "PREMIUM": { ".read": true, ".write": true },
    "PROFILES": { ".read": true, ".write": true },
    "users": { ".read": true, ".write": true },
    "CONCERTUSERS": { ".read": true, ".write": true },
    "LiveRooms": { ".read": true, ".write": true },
    "AGREEMENTS": { ".read": true, ".write": "auth != null" },
    "FEATURED_ARTIST_SONG": {
      ".read": true,
      "$ownerKey": {
        ".write": true,
        ".validate": "newData.hasChildren(['fileInp']) && newData.child('fileInp').isString() && newData.child('fileInp').val().length <= 2048"
      }
    },
    "FEATURED_SOCIAL_LINKS": { ".read": true, ".write": true },
    "FEATURE_REFERRAL_REQUESTS": { ".read": true, ".write": true },
    "FEATURE_REFERRAL_OUTBOX": { ".read": true, ".write": true },
    "REFERRAL_CODE_INDEX": { ".read": true, ".write": true },
    "REFERRAL_CODES_BY_USER": { ".read": true, ".write": true },
    "referralCounts": { ".read": true, ".write": true },
    "CONCERT_CHATS": {
      "$room": {
        "messages": {
          ".read": true,
          "$msgId": {
            ".write": "!data.exists()",
            ".validate": "newData.hasChildren(['text','ts']) && newData.child('text').isString() && newData.child('text').val().length <= 500 && newData.child('ts').isNumber() && (!newData.hasChild('epoch') || newData.child('epoch').isNumber())"
          }
        }
      }
    },
    "CONCERT_STICKIES": {
      "$room": {
        "notes": {
          ".read": true,
          "$noteId": {
            ".write": "!data.exists()",
            ".validate": "newData.hasChildren(['text','ts']) && newData.child('text').isString() && newData.child('text').val().length <= 280 && newData.child('ts').isNumber()"
          }
        }
      }
    },
    "PROFILE_STICKIES": {
      "$profileKey": {
        "notes": {
          ".read": true,
          "$noteId": {
            ".write": "!data.exists()",
            ".validate": "newData.hasChildren(['text','ts']) && newData.child('text').isString() && newData.child('text').val().length <= 280 && newData.child('ts').isNumber()"
          }
        }
      }
    },
    "FAN_ENGAGEMENT": {
      "$artistKey": {
        "events": {
          ".read": true,
          "$eid": {
            ".write": "!data.exists()",
            ".validate": "newData.hasChildren(['ts','songTitle']) && newData.child('ts').isNumber() && newData.child('songTitle').isString() && newData.child('songTitle').val().length <= 300"
          }
        }
      }
    },
    "LISTEN_JOURNEYS": {
      ".indexOn": ["uploaderKey", "ts"],
      "$jid": {
        ".read": true,
        ".write": "!data.exists() || (!data.child('nextTitle').exists() && newData.hasChild('nextTitle'))",
        ".validate": "newData.hasChildren(['ts','playedTitle']) && newData.child('ts').isNumber() && newData.child('playedTitle').isString() && newData.child('playedTitle').val().length <= 300 && (!newData.hasChild('nextTitle') || (newData.child('nextTitle').isString() && newData.child('nextTitle').val().length <= 300))"
      }
    },
    "ARTIST_JOURNEYS": {
      "$artistKey": {
        "$jid": {
          ".read": true,
          ".write": "!data.exists() || (!data.child('nextTitle').exists() && newData.hasChild('nextTitle'))",
          ".validate": "newData.hasChildren(['ts','playedTitle']) && newData.child('ts').isNumber() && newData.child('playedTitle').isString() && newData.child('playedTitle').val().length <= 300 && (!newData.hasChild('nextTitle') || (newData.child('nextTitle').isString() && newData.child('nextTitle').val().length <= 300))"
        }
      }
    },
    "ARTIST_POLLS": {
      ".read": true,
      "$pollId": {
        ".write": true,
        ".validate": "newData.hasChildren()",
        "votes": {
          "$vid": {
            ".read": true,
            ".write": "!data.exists() || (data.hasChild('ts') && data.hasChild('side') && newData.hasChild('ts') && newData.hasChild('side') && newData.child('ts').isNumber() && newData.child('side').isString() && (newData.child('side').val() == 'a' || newData.child('side').val() == 'b') && newData.child('ts').val() >= data.child('ts').val() + 604800000)",
            ".validate": "newData.hasChildren(['ts','side']) && newData.child('ts').isNumber() && newData.child('side').isString() && (newData.child('side').val() == 'a' || newData.child('side').val() == 'b')"
          }
        }
      }
    },
    "FOLLOWS": {
      "$artistKey": {
        ".read": true,
        "$followerKey": {
          ".write": true,
          ".validate": "newData.isBoolean()"
        }
      }
    },
    "FOLLOWING": {
      "$fanKey": {
        "$artistKey": {
          ".read": true,
          ".write": true,
          ".validate": "newData.isBoolean()"
        }
      }
    },
    "ARTIST_NOTICES": {
      "$artistKey": {
        ".indexOn": "ts",
        "$noticeId": {
          ".read": true,
          ".write": "!data.exists()",
          ".validate": "newData.hasChildren(['text','ts','ownerKey']) && newData.child('text').isString() && newData.child('text').val().length <= 800 && newData.child('ts').isNumber() && newData.child('ownerKey').isString() && newData.child('ownerKey').val() == $artistKey"
        }
      }
    },
    "USERNAME_REGISTRY": {
      ".read": true,
      "$uname": {
        ".write": "!data.exists()",
        ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 40"
      }
    },
    "CONTENT_REPORTS": {
      "$reportId": {
        ".read": false,
        ".write": "!data.exists()",
        ".validate": "newData.hasChildren(['ts','targetType','summary']) && newData.child('ts').isNumber() && newData.child('targetType').isString() && newData.child('targetType').val().length <= 32 && newData.child('summary').isString() && newData.child('summary').val().length <= 2000 && (!newData.hasChild('reporterKey') || (newData.child('reporterKey').isString() && newData.child('reporterKey').val().length <= 200)) && (!newData.hasChild('songTitle') || (newData.child('songTitle').isString() && newData.child('songTitle').val().length <= 400)) && (!newData.hasChild('artistName') || (newData.child('artistName').isString() && newData.child('artistName').val().length <= 400)) && (!newData.hasChild('uploaderKey') || (newData.child('uploaderKey').isString() && newData.child('uploaderKey').val().length <= 200))"
      }
    }
  }
}
