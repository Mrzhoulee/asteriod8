{
  "hosting": {
    "public": "firebase-hosting",
    "ignore": [
      "firebase.json",
      "**/node_modules/**",
      "**/*.md"
    ],
    "cleanUrls": true,
    "rewrites": [
      { "source": "/r/**",                       "function": "referralRedirect" },
      { "source": "/u/**",                       "function": "artistProfile" },
      { "source": "/t/**",                       "function": "trackPreview" },
      { "source": "/api/signup/attribute",       "function": "signupAttribute" },
      { "source": "/api/badge/**",               "function": "badgePng" },
      { "source": "/api/preview-audio/**",       "function": "previewAudio" },
      { "source": "/api/config",                 "function": "publicConfig" },
      { "source": "/api/migrate/referral-counts","function": "migrateReferralCountsRtdbToFirestore" },
      { "source": "**", "destination": "/index.html" }
    ],
    "headers": [
      {
        "source": "/__/auth/**",
        "headers": [{ "key": "Cache-Control", "value": "no-store" }]
      },
      {
        "source": "**/firebase-messaging-sw.js",
        "headers": [{ "key": "Service-Worker-Allowed", "value": "/" }]
      },
      {
        "source": "/.well-known/apple-app-site-association",
        "headers": [{ "key": "Content-Type", "value": "application/json" }]
      }
    ]
  },
  "functions": [
    {
      "codebase": "asteroid67",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "source": "asteroid67"
    },
    {
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local",
        ".env"
      ],
      "source": "functions"
    },
    {
      "source": "boostnotifier",
      "codebase": "boostnotifier",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ],
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "database": {
    "rules": "database.rules.json"
  }
}
