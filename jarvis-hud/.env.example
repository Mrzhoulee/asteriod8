# ─── Required ────────────────────────────────────────────────────────────────
# Anthropic — powers all agents
ANTHROPIC_API_KEY=sk-ant-...

# Groq Whisper — voice input
GROQ_API_KEY=gsk_...

# ─── Email ───────────────────────────────────────────────────────────────────
# Multiple accounts — number them 1, 2, 3… Tell JARVIS "send from Work" and it
# picks the right one. The first account is the default.
# Each needs a Gmail App Password: https://myaccount.google.com/apppasswords
# (Enable 2FA first, then create a 16-char App Password. Spaces are fine.)
GMAIL_ACCOUNT_1_LABEL=Personal
GMAIL_ACCOUNT_1_USER=me@gmail.com
GMAIL_ACCOUNT_1_PASS=xxxx xxxx xxxx xxxx

GMAIL_ACCOUNT_2_LABEL=Work
GMAIL_ACCOUNT_2_USER=work@company.com
GMAIL_ACCOUNT_2_PASS=yyyy yyyy yyyy yyyy

# Add as many as you like (GMAIL_ACCOUNT_3_*, _4_*, …).
# For a non-Gmail SMTP account, add HOST/PORT to its block:
# GMAIL_ACCOUNT_3_LABEL=Outlook
# GMAIL_ACCOUNT_3_HOST=smtp.office365.com
# GMAIL_ACCOUNT_3_PORT=587
# GMAIL_ACCOUNT_3_USER=you@company.com
# GMAIL_ACCOUNT_3_PASS=yourpassword

# Single account (legacy / simpler) — used only if no GMAIL_ACCOUNT_N_* are set.
# GMAIL_USER=you@gmail.com
# GMAIL_PASS=xxxx xxxx xxxx xxxx

# ─── Social posting (optional) ───────────────────────────────────────────────
# Best option: a webhook (Zapier / Make / Buffer / IFTTT) that fans out to any
# platform. JARVIS POSTs { platform, text, link } to it.
# SOCIAL_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/xxxx/yyyy

# Direct X / Twitter (OAuth2 user-context bearer token) — used if no webhook set.
# X_BEARER_TOKEN=...

# Without either, JARVIS opens a pre-filled compose window for one-click posting.

# ─── Web / analytics auth profiles (optional) ────────────────────────────────
# Define WEB_AUTH_<NAME> as a full Authorization header value. JARVIS references
# them by name (authProfile:"stripe") and never sees the raw secret.
# WEB_AUTH_STRIPE=Bearer sk_live_xxx
# WEB_AUTH_GA=Bearer ya29.xxx
# WEB_AUTH_GITHUB=Bearer ghp_xxx
