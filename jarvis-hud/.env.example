# ─── Required ────────────────────────────────────────────────────────────────
# Anthropic — powers all agents. NOTE: a Claude Pro/Max subscription does NOT
# include API access — add pay-as-you-go credits at console.anthropic.com → Billing.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: which Claude model powers JARVIS. Default is Opus 4.8 — the most
# capable model, so JARVIS reasons through and finishes complex multi-step jobs.
# To spend less, switch to Sonnet (balanced) or Haiku (cheapest, fastest):
#   claude-opus-4-8   ← default (smartest, priciest)
#   claude-sonnet-4-6 ← good balance of capability and cost
#   claude-haiku-4-5  ← cheapest and fastest
# JARVIS_MODEL=claude-opus-4-8

# Extended thinking: JARVIS reasons privately before acting — what makes it smart
# on hard requests. On by default. Set to "off" to disable, or raise the budget
# (in tokens) for deeper reasoning on tough tasks.
# JARVIS_THINKING=off
# JARVIS_THINKING_BUDGET=2048

# Groq Whisper — voice input
GROQ_API_KEY=gsk_...

# ─── Email ───────────────────────────────────────────────────────────────────
# Multiple accounts — number them 1, 2, 3… Tell JARVIS "send from Work" and it
# picks the right one. The first account is the default.
# Each needs a Gmail App Password: https://myaccount.google.com/apppasswords
# (Enable 2FA first, then create a 16-char App Password. Spaces are fine.)
GMAIL_ACCOUNT_1_LABEL=Personal
GMAIL_ACCOUNT_1_USER=me@gmail.com
GMAIL_ACCOUNT_1_PASS=xxxx xxxx xxxx xxxx

GMAIL_ACCOUNT_2_LABEL=Work
GMAIL_ACCOUNT_2_USER=work@company.com
GMAIL_ACCOUNT_2_PASS=yyyy yyyy yyyy yyyy

# Add as many as you like (GMAIL_ACCOUNT_3_*, _4_*, …).
# For a non-Gmail SMTP account, add HOST/PORT to its block:
# GMAIL_ACCOUNT_3_LABEL=Outlook
# GMAIL_ACCOUNT_3_HOST=smtp.office365.com
# GMAIL_ACCOUNT_3_PORT=587
# GMAIL_ACCOUNT_3_USER=you@company.com
# GMAIL_ACCOUNT_3_PASS=yourpassword

# Single account (legacy / simpler) — used only if no GMAIL_ACCOUNT_N_* are set.
# GMAIL_USER=you@gmail.com
# GMAIL_PASS=xxxx xxxx xxxx xxxx

# ─── Social posting (optional) ───────────────────────────────────────────────
# Easiest: Late (getlate.dev). Free signup, connect Instagram, TikTok, LinkedIn,
# X, Facebook once in their dashboard, and JARVIS posts to all of them with ONE
# key. No per-platform developer apps, no OAuth dance.
# Get a key: https://getlate.dev → sign up → Settings/API → copy API key.
# LATE_API_KEY=...

# Webhook fallback (Zapier / Make / IFTTT) — takes priority over Late if set.
# JARVIS POSTs { platform, text, link } to it.
# SOCIAL_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/xxxx/yyyy

# Buffer (legacy) — only works if you already have a Buffer developer token;
# Buffer no longer issues new ones.
# BUFFER_ACCESS_TOKEN=...

# Direct X / Twitter (OAuth2 user-context bearer token).
# X_BEARER_TOKEN=...

# Without any of the above, JARVIS opens a pre-filled browser compose window.

# ─── Google Analytics (GA4) ──────────────────────────────────────────────────
# RECOMMENDED — Service account: never expires, auto-refreshes. Full click-path
# in CREDENTIALS.md §6. The value can be a FILE PATH or the JSON pasted inline.
#   1) console.cloud.google.com → enable "Google Analytics Data API"
#   2) Create a service account → add a JSON key → download it
#   3) GA4 Admin → Property Access Management → add the service account email as Viewer
# GOOGLE_SERVICE_ACCOUNT_JSON=/Users/you/keys/ga4-sa.json
# GOOGLE_ANALYTICS_PROPERTY_ID=123456789   # GA4 Admin → Property Settings (numbers only)
#
# Quick-start alternative — OAuth2 bearer token (expires in ~1 hour):
#   https://developers.google.com/oauthplayground → scope: analytics.readonly
# GOOGLE_ANALYTICS_TOKEN=ya29.xxx
#
# After setting either, open Setup (⌘1) → "Test Google Analytics" to verify.

# ─── App Store Connect ────────────────────────────────────────────────────────
# Create API key at: https://appstoreconnect.apple.com/access/api
# Download the .p8 file — it can only be downloaded ONCE.
# APP_STORE_CONNECT_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# APP_STORE_CONNECT_KEY_ID=XXXXXXXXXX
# APP_STORE_CONNECT_PRIVATE_KEY=/Users/you/keys/AuthKey_XXXXXXXXXX.p8
# APP_STORE_CONNECT_VENDOR_NUMBER=12345678    # Settings → Payments & Financial Reports

# ─── TikTok ──────────────────────────────────────────────────────────────────
# Register your app at https://developers.tiktok.com, add the "Content Posting API"
# product, and register a redirect URI (https://). Then run the helper:
#   npm run auth:tiktok
# It walks the OAuth flow and prints ACCESS_TOKEN + OPEN_ID for you.
# See CREDENTIALS.md §4 for the click-by-click.
# TIKTOK_CLIENT_KEY=awxxxxxxxxxxxxx
# TIKTOK_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
# TIKTOK_REDIRECT_URI=https://localhost/    # must match what you registered (https only)
# TIKTOK_ACCESS_TOKEN=act.xxx               # ← filled by `npm run auth:tiktok`
# TIKTOK_OPEN_ID=xxx                        # ← filled by `npm run auth:tiktok`

# ─── Instagram ───────────────────────────────────────────────────────────────
# Business or Creator account required. Create an app at https://developers.facebook.com
# → add Instagram → "API setup with Instagram login", register a redirect URI, then run:
#   npm run auth:instagram
# It does the short→long-lived token exchange and finds your business ID.
# See CREDENTIALS.md §5 for the click-by-click.
# INSTAGRAM_APP_ID=1234567890               # the Instagram app ID (not the Meta app ID)
# INSTAGRAM_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
# INSTAGRAM_REDIRECT_URI=https://localhost/ # must match what you registered
# INSTAGRAM_ACCESS_TOKEN=IGAA...            # ← filled by `npm run auth:instagram` (~60 days)
# INSTAGRAM_BUSINESS_ID=17841...            # ← filled by `npm run auth:instagram`

# ─── Mailchimp ───────────────────────────────────────────────────────────────
# Get an API key: Mailchimp → Account → Extras → API keys. The "-usXX" suffix is
# your data center and is read automatically.
# MAILCHIMP_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-us21

# ─── Appfigures ──────────────────────────────────────────────────────────────
# Cross-store app analytics (App Store + Google Play). Create a Personal Access
# Token at Appfigures → Account → API; the client key is shown alongside it.
# APPFIGURES_TOKEN=...
# APPFIGURES_CLIENT_KEY=...

# ─── Fastlane AI / any other API ─────────────────────────────────────────────
# Tell JARVIS: "check Fastlane AI analytics" using web_request with authProfile:"fastlane"
# WEB_AUTH_FASTLANE=Bearer your-fastlane-api-key

# ─── Other web / analytics auth profiles ────────────────────────────────────
# WEB_AUTH_STRIPE=Bearer sk_live_xxx
# WEB_AUTH_GITHUB=Bearer ghp_xxx
