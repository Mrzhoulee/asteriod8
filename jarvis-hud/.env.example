# ─── Required ────────────────────────────────────────────────────────────────
# Anthropic — powers all agents
ANTHROPIC_API_KEY=sk-ant-...

# Groq Whisper — voice input
GROQ_API_KEY=gsk_...

# ─── Email ───────────────────────────────────────────────────────────────────
# Multiple accounts — number them 1, 2, 3… Tell JARVIS "send from Work" and it
# picks the right one. The first account is the default.
# Each needs a Gmail App Password: https://myaccount.google.com/apppasswords
# (Enable 2FA first, then create a 16-char App Password. Spaces are fine.)
GMAIL_ACCOUNT_1_LABEL=Personal
GMAIL_ACCOUNT_1_USER=me@gmail.com
GMAIL_ACCOUNT_1_PASS=xxxx xxxx xxxx xxxx

GMAIL_ACCOUNT_2_LABEL=Work
GMAIL_ACCOUNT_2_USER=work@company.com
GMAIL_ACCOUNT_2_PASS=yyyy yyyy yyyy yyyy

# Add as many as you like (GMAIL_ACCOUNT_3_*, _4_*, …).
# For a non-Gmail SMTP account, add HOST/PORT to its block:
# GMAIL_ACCOUNT_3_LABEL=Outlook
# GMAIL_ACCOUNT_3_HOST=smtp.office365.com
# GMAIL_ACCOUNT_3_PORT=587
# GMAIL_ACCOUNT_3_USER=you@company.com
# GMAIL_ACCOUNT_3_PASS=yourpassword

# Single account (legacy / simpler) — used only if no GMAIL_ACCOUNT_N_* are set.
# GMAIL_USER=you@gmail.com
# GMAIL_PASS=xxxx xxxx xxxx xxxx

# ─── Social posting (optional) ───────────────────────────────────────────────
# Best option: a webhook (Zapier / Make / Buffer / IFTTT) that fans out to any
# platform. JARVIS POSTs { platform, text, link } to it.
# SOCIAL_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/xxxx/yyyy

# Direct X / Twitter (OAuth2 user-context bearer token) — used if no webhook set.
# X_BEARER_TOKEN=...

# Without either, JARVIS opens a pre-filled compose window for one-click posting.

# ─── Google Analytics (GA4) ──────────────────────────────────────────────────
# Option A: OAuth2 bearer token (~1hr expiry — simplest to start)
# Get one at: https://developers.google.com/oauthplayground → scope: analytics.readonly
# GOOGLE_ANALYTICS_TOKEN=ya29.xxx
# GOOGLE_ANALYTICS_PROPERTY_ID=123456789   # numbers from GA4 Admin → Property Settings

# Option B: Service account JSON (auto-refreshes — recommended for production)
# Create at https://console.cloud.google.com → IAM → Service Accounts → Keys → JSON
# Share your GA4 property with the service account email as "Viewer"
# GOOGLE_SERVICE_ACCOUNT_JSON=/Users/you/keys/ga4-sa.json
# GOOGLE_ANALYTICS_PROPERTY_ID=123456789

# ─── App Store Connect ────────────────────────────────────────────────────────
# Create API key at: https://appstoreconnect.apple.com/access/api
# Download the .p8 file — it can only be downloaded ONCE.
# APP_STORE_CONNECT_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# APP_STORE_CONNECT_KEY_ID=XXXXXXXXXX
# APP_STORE_CONNECT_PRIVATE_KEY=/Users/you/keys/AuthKey_XXXXXXXXXX.p8
# APP_STORE_CONNECT_VENDOR_NUMBER=12345678    # Settings → Payments & Financial Reports

# ─── TikTok ──────────────────────────────────────────────────────────────────
# Register your app at https://developers.tiktok.com
# Add "Content Posting API" product. Complete OAuth to get these two values.
# TIKTOK_ACCESS_TOKEN=act.xxx
# TIKTOK_OPEN_ID=xxx                        # your TikTok user ID (from OAuth response)

# ─── Instagram ───────────────────────────────────────────────────────────────
# Requires a Business or Creator account linked to a Facebook Page.
# Create app at https://developers.facebook.com → Instagram Graph API
# Permissions needed: instagram_basic, instagram_content_publish, instagram_manage_insights
# INSTAGRAM_ACCESS_TOKEN=EAAG...            # long-lived user token (~60 days)
# INSTAGRAM_BUSINESS_ID=17841...           # GET /me?fields=id,username with your token

# ─── Fastlane AI / any other API ─────────────────────────────────────────────
# Tell JARVIS: "check Fastlane AI analytics" using web_request with authProfile:"fastlane"
# WEB_AUTH_FASTLANE=Bearer your-fastlane-api-key

# ─── Other web / analytics auth profiles ────────────────────────────────────
# WEB_AUTH_STRIPE=Bearer sk_live_xxx
# WEB_AUTH_GITHUB=Bearer ghp_xxx
